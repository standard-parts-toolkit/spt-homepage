---
interface Props {
  variant?: 'full' | 'mark';
  class?: string;
}
const { variant = 'full', class: className = '' } = Astro.props;
---

{variant === 'mark' ? (
  <span class:list={['inline-flex h-9 w-9 items-center justify-center rounded-lg font-extrabold tracking-tight text-[var(--primary-fg)]', className]} style="background: var(--primary)">
    SPT
  </span>
) : (
  <span class:list={['inline-flex items-center gap-2 font-extrabold tracking-tight', className]}>
    <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-[var(--primary-fg)] text-sm" style="background: var(--primary)">SPT</span>
    <span class="text-lg" style="color: var(--text)">Standard Parts Toolkit</span>
  </span>
)}
