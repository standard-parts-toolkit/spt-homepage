---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DualCTA from '../../components/DualCTA.astro';

export async function getStaticPaths() {
  const cases = await getCollection('caseStudies', ({ data }) => !data.draft);
  return cases.map((c) => ({
    params: { slug: c.id },
    props: { c },
  }));
}

const { c } = Astro.props;
const { Content } = await render(c);
---

<BaseLayout title={`${c.data.title} — SPT Customers`} description={c.data.subhead}>

  <article class="section pt-12 sm:pt-20">
    <div class="mx-auto max-w-3xl">
      <span class={c.data.customerType === 'Manufacturer' ? 'tag tag-primary' : 'tag'}>{c.data.customerType} · Case study</span>
      <h1 class="mt-3 text-3xl font-extrabold leading-[1.15] tracking-tight sm:text-4xl lg:text-5xl" style="color: var(--text)">
        {c.data.title}
      </h1>
      <p class="lede mt-4">{c.data.subhead}</p>

      <dl class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
        {[
          ['Industry',     c.data.industry],
          ['Catalog size', c.data.catalogSize],
          ['Data source',  c.data.dataSource],
          ['Outcome',      c.data.outcome],
        ].map(([label, value]) => (
          <div class="card" style="padding: 0.85rem 1rem">
            <dt class="text-xs font-semibold uppercase tracking-wider" style="color: var(--text-subtle)">{label}</dt>
            <dd class="mt-1 text-sm font-semibold" style="color: var(--text)">{value}</dd>
          </div>
        ))}
      </dl>

      <div class="mt-4 flex flex-wrap gap-2 text-xs" style="color: var(--text-subtle)">
        <span class="font-semibold uppercase tracking-wider">Modules used:</span>
        {c.data.modulesUsed.map((m) => (<span class="tag" style="font-size: 0.7rem">{m}</span>))}
      </div>

      <div class="post-body mt-10">
        <Content />
      </div>

      <p class="mt-12">
        <a href="/customers/" class="inline-flex items-center gap-1 text-sm font-semibold" style="color: var(--primary)">
          <span aria-hidden="true">←</span> All customers
        </a>
      </p>
    </div>
  </article>

  <DualCTA />

</BaseLayout>
