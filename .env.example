# Public env vars (exposed to client). Update before deploy.
# Get IDs from https://formspree.io/forms after creating each form.
PUBLIC_FORMSPREE_CONTACT_ID=xxxxxxxx
PUBLIC_FORMSPREE_DEMO_ID=xxxxxxxx
PUBLIC_FORMSPREE_NEWSLETTER_ID=xxxxxxxx

# GA4 measurement ID (G-XXXXXXXXXX) — leave blank to disable analytics
PUBLIC_GA4_ID=

# Shopify App Store install URL — replace placeholder when listed
PUBLIC_SHOPIFY_APP_URL=#install-on-shopify
